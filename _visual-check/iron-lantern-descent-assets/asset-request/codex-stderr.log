from pathlib import Path
from PIL import Image, ImageOps

base = Path('/mnt/f/_evolve/millrace-games/auto-games')
tmp = base / 'tmp/imagegen/iron-lantern-descent'
out = base / 'games/iron-lantern-descent/assets'
out.mkdir(parents=True, exist_ok=True)

# Transparent sprites: resize full source canvas to preserve authored padding/layout.
for name, size in [
    ('lantern-anchor', (256, 256)),
    ('drill-tool', (256, 256)),
    ('oxygen-light-icons', (384, 128)),
]:
    im = Image.open(tmp / f'{name}-alpha.png').convert('RGBA')
    im = im.resize(size, Image.Resampling.LANCZOS)
    im.save(out / f'{name}.png', 'PNG', optimize=True)

# Opaque texture: center-crop/resize square material.
