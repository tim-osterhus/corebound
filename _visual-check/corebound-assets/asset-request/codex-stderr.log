from pathlib import Path
from PIL import Image, ImageOps, ImageEnhance, ImageFilter
import json, math
try:
    import numpy as np
except Exception as e:
    raise SystemExit(f'numpy unavailable: {e}')

workdir = Path('/mnt/f/_evolve/millrace-games/auto-games')
src = workdir / 'tmp/imagegen/corebound-src'
out = workdir / 'games/corebound/assets'

for d in ['rig','surface','terrain','readables','hud','upgrades']:
    (out / d).mkdir(parents=True, exist_ok=True)

RESAMPLE = Image.Resampling.LANCZOS

def remove_green_alpha(im: Image.Image) -> Image.Image:
    im = im.convert('RGBA')
    arr = np.asarray(im).astype(np.float32)
    r, g, b, a = arr[...,0], arr[...,1], arr[...,2], arr[...,3]
    max_rb = np.maximum(r, b)
    green_score = g - max_rb
    # Strong chroma-key removal while preserving teal/cyan subject lights where blue ~= green.
    hard = (g > 135) & (green_score > 65)
    soft = (g > 95) & (green_score > 24)
    t = np.clip((green_score - 24) / 76, 0, 1) * np.clip((g - 95) / 80, 0, 1)
    new_alpha = a.copy()
    new_alpha[soft] = np.minimum(new_alpha[soft], 255 * (1 - t[soft]))
    new_alpha[hard] = 0
    # Despill antialiased edges.
    edge = new_alpha < 255
    arr[...,1][edge] = np.minimum(arr[...,1][edge], max_rb[edge] * 1.05)
    arr[...,3] = np.clip(new_alpha, 0, 255)
    return Image.fromarray(np.asarray(np.clip(arr, 0, 255), dtype=np.uint8), 'RGBA')

def bbox_for_alpha(im: Image.Image, threshold=20):
    a = np.asarray(im.getchannel('A'))
    ys, xs = np.where(a > threshold)
    if len(xs) == 0:
        return None
    return int(xs.min()), int(ys.min()), int(xs.max()+1), int(ys.max()+1)

def groups_by_x(im: Image.Image, expected: int, threshold=30):
    a = np.asarray(im.getchannel('A'))
    occupied = (a > threshold).sum(axis=0) > 2
    runs = []
    in_run = False
    start = 0
    for i, v in enumerate(occupied):
        if v and not in_run:
            start = i; in_run = True
        elif not v and in_run:
            runs.append([start, i]); in_run = False
    if in_run:
        runs.append([start, len(occupied)])
    if not runs:
        return []
    # Merge object-internal gaps; real cell gaps are much larger.
    merge_gap = max(18, im.width // (expected * 9))
    merged = [runs[0]]
    for s, e in runs[1:]:
        if s - merged[-1][1] <= merge_gap:
            merged[-1][1] = e
        else:
            merged.append([s, e])
    # If small detached pieces split an icon, progressively merge nearest gaps until expected count.
    while len(merged) > expected:
        gaps = [(merged[i+1][0] - merged[i][1], i) for i in range(len(merged)-1)]
        _, idx = min(gaps)
        merged[idx][1] = merged[idx+1][1]
        del merged[idx+1]
    if len(merged) < expected:
        box = bbox_for_alpha(im, threshold) or (0, 0, im.width, im.height)
        x0, _, x1, _ = box
        cell = (x1 - x0) / expected
        merged = [[round(x0 + i*cell), round(x0 + (i+1)*cell)] for i in range(expected)]
    return [(int(s), int(e)) for s, e in merged[:expected]]

def crop_bbox_in_x(im: Image.Image, xr, threshold=20, pad=8):
    a = np.asarray(im.getchannel('A'))
    x0, x1 = xr
    sub = a[:, max(0,x0):min(im.width,x1)] > threshold
    ys, xs = np.where(sub)
    if len(xs) == 0:
        return im.crop((x0, 0, x1, im.height))
    bx0 = max(0, x0 + int(xs.min()) - pad)
    bx1 = min(im.width, x0 + int(xs.max()) + 1 + pad)
    by0 = max(0, int(ys.min()) - pad)
    by1 = min(im.height, int(ys.max()) + 1 + pad)
    return im.crop((bx0, by0, bx1, by1))

def paste_fit_cell(canvas, crop, cell_x, cell_y, cell_w, cell_h, max_w, max_h, y_bias=0.5):
    box = bbox_for_alpha(crop, 8)
    if box:
        crop = crop.crop(box)
    scale = min(max_w / crop.width, max_h / crop.height)
    nw = max(1, int(round(crop.width * scale)))
    nh = max(1, int(round(crop.height * scale)))
    resized = crop.resize((nw, nh), RESAMPLE)
    px = cell_x + (cell_w - nw) // 2
    py = cell_y + int(round((cell_h - nh) * y_bias))
    canvas.alpha_composite(resized, (px, py))

def make_sprite_strip():
    im = Image.open(src / 'mantis-strip-source.png')
    rgba = remove_green_alpha(im)
    groups = groups_by_x(rgba, 4, threshold=25)
    canvas = Image.new('RGBA', (320, 80), (0,0,0,0))
    for i, xr in enumerate(groups):
        crop = crop_bbox_in_x(rgba, xr, threshold=25, pad=12)
        paste_fit_cell(canvas, crop, i*80, 0, 80, 80, 76, 66, y_bias=0.62)
    canvas.save(out / 'rig/mantis-rig-motion-strip.png')

def fit_cover(im, size, focal_y=0.5):
    tw, th = size
    w, h = im.size
    target_aspect = tw / th
    aspect = w / h
    if aspect > target_aspect:
        crop_w = int(round(h * target_aspect))
        x0 = max(0, (w - crop_w)//2)
        box = (x0, 0, x0 + crop_w, h)
    else:
        crop_h = int(round(w / target_aspect))
        y0 = int(round((h - crop_h) * focal_y))
        y0 = max(0, min(h - crop_h, y0))
        box = (0, y0, w, y0 + crop_h)
    return im.crop(box).resize(size, RESAMPLE)

def make_surfaces():
    facilities = Image.open(src / 'surface-facilities-source.png').convert('RGB')
    # Bias high enough to keep gantry/relay tops, while retaining the base deck.
    facilities = fit_cover(facilities, (640,160), focal_y=0.18)
    facilities.save(out / 'surface/surface-facilities-panel.png')
    launch = Image.open(src / 'launch-shaft-source.png').convert('RGB')
    ImageOps.fit(launch, (320,320), method=RESAMPLE, centering=(0.5,0.5)).save(out / 'surface/launch-shaft-context.png')

def make_seamless_tile(path_in, path_out):
    im = Image.open(path_in).convert('RGB')
    im = ImageOps.fit(im, (160,160), method=RESAMPLE, centering=(0.5,0.5)).resize((128,128), RESAMPLE)
    im = ImageEnhance.Contrast(im).enhance(1.06)
    im = ImageEnhance.Sharpness(im).enhance(1.15)
    arr = np.asarray(im).astype(np.float32)
    h, w, _ = arr.shape
    blend = 12
    # Wrap-blend opposing edges so the final 128 tile reads cleanly in a grid.
    for i in range(blend):
        t = (i + 1) / (blend + 1)
        left = arr[:, i, :].copy()
        right = arr[:, w-1-i, :].copy()
        avg = left * (1-t) + right * t
        avg2 = right * (1-t) + left * t
        arr[:, i, :] = avg
        arr[:, w-1-i, :] = avg2
        top = arr[i, :, :].copy()
        bottom = arr[h-1-i, :, :].copy()
        avg = top * (1-t) + bottom * t
        avg2 = bottom * (1-t) + top * t
        arr[i, :, :] = avg
        arr[h-1-i, :, :] = avg2
    Image.fromarray(np.asarray(np.clip(arr,0,255), dtype=np.uint8), 'RGB').save(path_out)

def make_tiles():
    make_seamless_tile(src / 'loam-gritstone-source.png', out / 'terrain/loam-gritstone-tile.png')
    make_seamless_tile(src / 'basalt-core-source.png', out / 'terrain/basalt-core-tile.png')
    make_seamless_tile(src / 'pressure-glass-source.png', out / 'terrain/pressure-glass-tile.png')

def make_atlas(src_name, out_rel, count, width, height, max_size):
    im = Image.open(src / src_name)
    rgba = remove_green_alpha(im)
    groups = groups_by_x(rgba, count, threshold=25)
    canvas = Image.new('RGBA', (width, height), (0,0,0,0))
    cell_w = width // count
    for i, xr in enumerate(groups):
        crop = crop_bbox_in_x(rgba, xr, threshold=25, pad=12)
        paste_fit_cell(canvas, crop, i*cell_w, 0, cell_w, height, max_size, max_size, y_bias=0.5)
    canvas.save(out / out_rel)

def make_atlases():
    make_atlas('ore-hazard-atlas-source.png', 'readables/ore-hazard-atlas.png', 6, 384, 128, 58)
    make_atlas('hud-icon-atlas-source.png', 'hud/hud-icon-atlas.png', 5, 320, 64, 58)
    make_atlas('upgrade-research-atlas-source.png', 'upgrades/upgrade-research-atlas.png', 8, 512, 128, 60)

make_sprite_strip()
make_surfaces()
make_tiles()
make_atlases()

# Validate dimensions/alpha.
checks = []
expected = {
    'rig/mantis-rig-motion-strip.png': (320,80,'RGBA'),
    'surface/surface-facilities-panel.png': (640,160,'RGB'),
